<!DOCTYPE html>
<html lang="hi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>EXAM ENGINE: The VU Power</title>
    <style>
        :root { 
            --cbt-blue: #1664c0; --cbt-light-blue: #e6f0fa; --cbt-green: #2fa534; 
            --cbt-red: #d9534f; --cbt-purple: #7030a0; --bg: #f4f7f6; --text: #333333; 
            --border: #cccccc; --review-bg: #f4f8fb; --locked: #e0e0e0;
        }
        * { box-sizing: border-box; font-family: Arial, sans-serif; }
        
        /* Mobile Viewport Height Fix */
        html { height: 100%; }
        body { margin: 0; background: var(--bg); color: var(--text); display: flex; flex-direction: column; height: 100%; height: 100dvh; overflow: hidden; }
        
        /* REMOVE NUMBER INPUT SPINNERS (Arrows) */
        input[type=number]::-webkit-inner-spin-button, 
        input[type=number]::-webkit-outer-spin-button { 
            -webkit-appearance: none; 
            margin: 0; 
        }
        input[type=number] {
            -moz-appearance: textfield; 
        }

        .btn { padding: 6px 16px; border: none; border-radius: 4px; cursor: pointer; font-weight: bold; color: white; transition: 0.2s; font-size: 0.95rem; }
        .btn-blue { background: var(--cbt-blue); }
        .btn-blue:hover { background: #0b4a99; }
        .btn-green { background: var(--cbt-green); }
        .btn-outline { background: #fff; color: #333; border: 1px solid #ccc; }
        .btn-outline:hover { background: #f0f0f0; }
        .btn:disabled { opacity: 0.5; cursor: not-allowed; }
        
        /* SECURITY LOCK SCREEN */
        #lock-screen { display: flex; flex-direction: column; align-items: center; justify-content: center; height: 100%; background: var(--bg); width: 100%; z-index: 9999; }
        .lock-card { background: white; padding: 40px; border-radius: 12px; box-shadow: 0 4px 20px rgba(0,0,0,0.08); text-align: center; border-top: 5px solid var(--cbt-red); width: 90%; max-width: 400px; }
        .lock-input { font-size: 1.2rem; padding: 12px; width: 100%; text-align: center; letter-spacing: 2px; margin-bottom: 20px; border: 2px solid var(--border); border-radius: 6px; outline: none; transition: 0.2s;}
        .lock-input:focus { border-color: var(--cbt-blue); }

        /* Home Dashboard Redesign */
        #home-screen { display: flex; flex-direction: column; align-items: center; justify-content: flex-start; height: 100%; padding: 20px; overflow-y: auto; }
        .home-card { background: white; padding: 40px; border-radius: 12px; box-shadow: 0 4px 20px rgba(0,0,0,0.08); max-width: 800px; width: 100%; text-align: center; border-top: 5px solid var(--cbt-blue); margin: auto; position: relative; }
        
        .home-header-row { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 20px; gap: 10px; }
        .header-titles { text-align: left; flex: 1; min-width: 0; display: flex; gap: 15px; align-items: center; }
        
        .logo-container { width: 70px; height: 70px; flex-shrink: 0; border-radius: 12px; overflow: hidden; box-shadow: 0 4px 10px rgba(0,0,0,0.1); border: 2px solid var(--cbt-blue); position: relative; background: var(--cbt-light-blue); }
        .logo-placeholder { width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; color: var(--cbt-blue); font-weight: 900; font-size: 1.5rem; }
        
        .home-title { color: var(--text); font-size: 2rem; margin: 0; font-weight: 900; letter-spacing: 1px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
        .home-tagline { color: var(--cbt-blue); font-size: 1rem; font-weight: bold; margin: 0; }
        .home-subtitle { color: #888; margin: 0; font-size: 0.85rem; }
        
        .settings-vault { display: flex; flex-direction: column; gap: 8px; align-items: flex-end; flex-shrink: 0; }
        .lock-vault-btn, .lang-vault-btn { height: 34px; width: 100px; box-sizing: border-box; font-size: 0.85rem; padding: 0 8px; cursor: pointer; background: #eee; border-radius: 5px; font-weight: bold; border: 1px solid #ddd; display: flex; align-items: center; justify-content: center; gap: 6px; color: #333; }
        .lang-vault-btn select { background: transparent; border: none; font-weight: bold; cursor: pointer; outline: none; padding: 0; margin: 0; height: 100%; width: 100%; text-align: center; }
        .lock-vault-btn:hover { background: #ddd; }

        /* Global Subject Toggles */
        .subject-toggle-container { display: flex; flex-wrap: wrap; gap: 8px; justify-content: center; margin-top: 10px;}
        .sub-toggle-btn { padding: 6px 14px; border-radius: 20px; border: 1px solid var(--cbt-blue); background: white; color: var(--cbt-blue); cursor: pointer; font-size: 0.85rem; font-weight: bold; transition: 0.2s; }
        .sub-toggle-btn.active { background: var(--cbt-blue); color: white; }

        .revision-block { grid-column: 1 / -1; background: linear-gradient(135deg, #7030a0, #4a235a); color: white; padding: 25px; border-radius: 12px; text-align: center; box-shadow: 0 4px 15px rgba(112, 48, 160, 0.3); margin-bottom: 10px; cursor: pointer; border: none; transition: 0.2s; }
        .revision-block:hover { transform: translateY(-3px); box-shadow: 0 6px 20px rgba(112, 48, 160, 0.4); }

        /* CONSTAINED CONTENT WRAPPER FOR FULL-WIDTH SCREENS */
        .content-wrapper { max-width: 1000px; width: 100%; margin: 0 auto; }

        /* The VU Revision Page Styles */
        #revision-screen { display: none; flex-direction: column; width: 100%; height: 100%; overflow: hidden; background: var(--bg); padding: 0; }
        .rev-fixed-header { padding: 15px 20px 5px 20px; background: var(--bg); flex-shrink: 0; z-index: 10; border-bottom: 1px solid #e0e0e0; width: 100%; }
        .rev-fixed-header .header { margin-bottom: 10px; padding: 10px; background: white; border-radius: 8px; box-shadow: 0 2px 5px rgba(0,0,0,0.05); border: none; }
        .rev-fixed-header .filter-bar { display: flex; gap: 10px; overflow-x: auto; padding-bottom: 10px; align-items: center; border-bottom: none; margin-bottom: 0; }
        
        #revision-feed-scroll-area { flex: 1; overflow-y: auto; width: 100%; padding-top: 15px; }
        
        .rev-fixed-footer { background: var(--bg); padding: 10px 20px calc(10px + env(safe-area-inset-bottom)); flex-shrink: 0; border-top: 1px solid var(--border); box-shadow: 0 -4px 15px rgba(0,0,0,0.05); z-index: 10; width: 100%; }

        .filter-chip { padding: 6px 12px; border-radius: 20px; border: 1px solid #ccc; background: white; font-size: 0.85rem; white-space: nowrap; cursor: pointer; font-weight: bold; transition: 0.2s;}
        .filter-chip.active { background: var(--cbt-purple); color: white; border-color: var(--cbt-purple); }
        .toggle-container { display: flex; align-items: center; gap: 5px; font-size: 0.85rem; font-weight: bold; white-space: nowrap; background: #fdfaf4; padding: 4px 10px; border-radius: 20px; border: 1px solid #f5e6d3; margin-left: auto;}

        .rev-card { background: white; border-radius: 12px; padding: 15px; margin-bottom: 15px; box-shadow: 0 4px 10px rgba(0,0,0,0.08); border: 1px solid #eaeaea; }
        .rev-stats-bar { display: flex; justify-content: space-between; align-items: center; border-bottom: 1px dashed #ddd; padding-bottom: 8px; margin-bottom: 12px; font-size: 0.75rem; color: #666; font-family: monospace; }
        .rev-actions { display: flex; gap: 8px; }
        .rev-action-btn { background: #eee; border: 1px solid #ccc; border-radius: 4px; padding: 3px 8px; font-size: 0.8rem; font-weight: bold; cursor: pointer; }
        .rev-q-text { font-size: 1.1rem; font-weight: bold; margin-bottom: 15px; line-height: 1.5; color: #333; }
        .rev-options-grid { display: flex; flex-direction: column; gap: 8px; }
        .rev-opt-btn { text-align: left; padding: 12px 15px; border: 2px solid #ddd; border-radius: 8px; background: white; font-size: 0.95rem; font-weight: bold; cursor: pointer; transition: 0.2s; }
        .rev-opt-btn:disabled { cursor: not-allowed; opacity: 1; }

        /* REVISION SLIDER - Capped at 1000px and Centered */
        .rev-slider { 
            position: fixed; bottom: 0; left: 0; right: 0; margin: 0 auto; 
            width: 100%; max-width: 1000px; 
            max-height: 85vh; background: white; border-radius: 20px 20px 0 0; 
            box-shadow: 0 -5px 25px rgba(0,0,0,0.2); 
            transform: translateY(100%); transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1); 
            z-index: 9999; display: flex; flex-direction: column; padding: 0; 
        }
        .rev-slider.open { transform: translateY(0); }

        .modes-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 20px; width: 100%; margin-top: 20px; }
        .mode-section { background: #f9f9f9; border: 1px solid #eee; padding: 20px; border-radius: 8px; text-align: left; display: flex; flex-direction: column; margin: 0; }
        .mode-section button { margin-top: auto; }
        .lang-section-full { grid-column: 1 / -1; }
        
        .mode-title { font-weight: bold; color: #333; margin-bottom: 5px; font-size: 1.1rem; }
        .mode-desc { font-size: 0.85rem; color: #666; margin-bottom: 15px; }
        select { width: 100%; padding: 10px; margin-bottom: 15px; border: 1px solid var(--border); border-radius: 4px; outline: none;}
        
        /* CBT Layout - Desktop */
        .header { display: flex; justify-content: space-between; align-items: center; padding: 10px 20px; border-bottom: 2px solid var(--border); box-shadow: 0 2px 5px rgba(0,0,0,0.1); flex-shrink: 0; background: white; flex-wrap: wrap;}
        .header-left { display: flex; align-items: center; gap: 15px; flex: 1; min-width: 150px;}
        .home-icon { cursor: pointer; font-size: 1.2rem; background: #eee; padding: 5px 10px; border-radius: 5px; color: #333; text-decoration: none;}
        .home-icon:hover { background: #ddd; }
        
        /* --- SYMMETRICAL TIMER LAYOUT --- */
        .timer-container { display: flex; gap: 10px; align-items: center; flex-shrink: 0;}
        .timer-module { display: flex; flex-direction: column; align-items: center; width: 85px; }
        .timer-label { font-size: 0.7rem; font-weight: bold; color: #888; margin-bottom: 3px; text-transform: uppercase; letter-spacing: 0.5px; }
        
        .timer-display { 
            width: 100%; text-align: center; padding: 4px 0; border-radius: 6px; 
            font-family: 'Courier New', Courier, monospace; font-size: 1.1rem; font-weight: 900; 
        }
        
        /* SWAPPED COLORS: Section = RED, Total = BLUE */
        .display-sec { background: #ffeeee; color: var(--cbt-red); border: 1px solid #f5d0d0; }
        .display-total { background: var(--cbt-light-blue); color: var(--cbt-blue); border: 1px solid #d0e1f5; }
        
        .pause-btn-fixed {
            width: 38px; height: 38px; border-radius: 50%; background: #444; color: white;
            border: none; cursor: pointer; font-size: 1rem; display: flex; 
            align-items: center; justify-content: center; transition: 0.2s; flex-shrink: 0;
            margin-left: 5px; box-shadow: 0 2px 5px rgba(0,0,0,0.1);
        }
        .pause-btn-fixed:hover { background: #222; transform: scale(1.05); }

        .main-content { display: flex; flex: 1; overflow: hidden; background: white; position: relative;}
        .left-panel { flex: 1; display: flex; flex-direction: column; border-right: 1px solid var(--border); min-width: 0; }
        .right-panel { width: 280px; flex-shrink: 0; background: #fdfdfd; display: flex; flex-direction: column; }
        
        .top-action-bar { padding: 10px 20px; border-bottom: 1px solid var(--border); display: flex; gap: 15px; flex-wrap: wrap; align-items: center; background: #fff; flex-shrink: 0; justify-content: center; }
        
        .q-header { padding: 10px 20px; font-weight: bold; flex-shrink: 0; font-size: 1.1rem; display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid #f0f0f0; background: #fafafa;}
        .badge { padding: 4px 8px; border-radius: 4px; color: white; font-size: 0.8rem; margin-left: 10px;}
        .q-body { padding: 20px; flex: 1; overflow-y: auto; font-size: 1.15rem; line-height: 1.6; }
        
        /* RESTORED ORIGINAL OPTIONS LAYOUT */
        .option-row { 
            display: flex; align-items: stretch; margin-bottom: 12px; 
            border: 1px solid var(--border); border-radius: 4px; 
            background: #fff; cursor: pointer; transition: 0.2s; 
        }
        .radio-square { 
            width: 45px; display: flex; justify-content: center; 
            align-items: center; border-right: 1px solid var(--border); 
            background: #f9f9f9; border-radius: 4px 0 0 4px; 
        }
        .radio-square input { transform: scale(1.3); cursor: pointer; margin: 0; }
        .option-text { padding: 12px 15px; flex: 1; display: flex; align-items: center; font-size: 1.1rem; }
        
        .opt-correct { background: #e8f5e9 !important; border-color: var(--cbt-green) !important; font-weight: bold; }
        .opt-incorrect { background: #ffebee !important; border-color: var(--cbt-red) !important; }
        
        .palette-header { padding: 10px; background: var(--cbt-light-blue); font-weight: bold; border-bottom: 1px solid var(--border); flex-shrink: 0; color: var(--cbt-blue); font-size: 0.9rem;}
        .palette-container-wrapper { flex: 1; overflow-y: auto; }
        .palette-section-title { background: #eee; padding: 8px 10px; font-size: 0.8rem; font-weight: bold; border-bottom: 1px solid #ccc; border-top: 1px solid #ccc; display: flex; justify-content: space-between;}
        .palette-grid { display: grid; grid-template-columns: repeat(5, 40px); justify-content: center; gap: 8px; padding: 15px; align-content: start; }
        .pal-btn { width: 40px; height: 40px; border: 1px solid var(--border); border-radius: 6px; background: white; cursor: pointer; font-weight: bold; font-size: 0.9rem; display: flex; align-items: center; justify-content: center; color: #333; margin: 0 auto; transition: 0.2s; }
        
        /* Faded out palette items for filters */
        .filtered-out { opacity: 0.15 !important; cursor: not-allowed !important; transform: scale(0.9) !important; background: #fafafa !important; border-color: #eee !important; color: #ccc !important; }

        .status-answered { background: var(--cbt-green); color: white; border-color: var(--cbt-green); }
        .status-not-answered { background: var(--cbt-red); color: white; border-color: var(--cbt-red); }
        .status-review { background: var(--cbt-purple); color: white; border-color: var(--cbt-purple); }
        .status-active { box-shadow: 0 0 0 3px rgba(22, 100, 192, 0.4); border-color: var(--cbt-blue); }
        
        /* REVIEW MODE COLORS */
        .rev-correct { background: var(--cbt-green); color: white; border-color: var(--cbt-green); }
        .rev-incorrect { background: var(--cbt-red); color: white; border-color: var(--cbt-red); }
        .rev-skipped { background: #888888 !important; color: white !important; border-color: #777777 !important; }
        
        .status-locked { background: var(--locked) !important; color: #999 !important; border-color: #ccc !important; cursor: not-allowed; opacity: 0.6; }

        .solution-box { margin-top: 25px; padding: 15px; border: 1px solid #b3d4fc; background: #eef6ff; border-radius: 6px; position: relative; }
        
        .uid-tag { 
            display: inline-block; font-size: 0.85rem; color: var(--cbt-blue); margin-top: 15px; 
            font-family: monospace; background: #fff; border: 1px dashed var(--cbt-blue); 
            padding: 8px 12px; border-radius: 6px; cursor: pointer; transition: 0.2s; text-align: left;
        }
        .uid-tag:hover { background: #dceaf9; }
        
        /* FULL-WIDTH ANALYSIS SCREEN SKELETON */
        #analysis-screen { display: none; flex-direction: column; height: 100%; background: var(--bg); }
        .analysis-content { flex: 1; overflow-y: auto; padding: 20px; }

        .dashboard-card { background: white; padding: 30px; border-radius: 12px; box-shadow: 0 4px 20px rgba(0,0,0,0.08); max-width: 1000px; margin: 0 auto; border-top: 5px solid var(--cbt-blue);}
        .stat-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(120px, 1fr)); gap: 15px; margin-top: 20px; text-align: center;}
        .stat-box { padding: 15px; background: #f9f9f9; border-radius: 8px; border: 1px solid #eee; }
        .stat-value { font-size: 1.5rem; font-weight: bold; margin-top: 5px; color: var(--cbt-blue); }
        
        .subject-analysis { margin-top: 30px; border-top: 1px solid #eee; padding-top: 20px;}
        .sub-card { background: #fcfcfc; border: 1px solid #e0e0e0; border-radius: 8px; padding: 15px; margin-bottom: 10px; display: flex; flex-wrap: wrap; justify-content: space-between; align-items: center;}
        .sub-name { font-weight: bold; font-size: 1.1rem; color: var(--cbt-blue); width: 100px;}
        .sub-metrics { display: flex; gap: 15px; flex-wrap: wrap; flex: 1; justify-content: space-around;}
        .metric { font-size: 0.85rem; text-align: center;}
        .metric span { display: block; font-weight: bold; font-size: 1.1rem; color: #333;}
        
        .insights-area { margin-top: 30px; background: #f4f8fb; padding: 20px; border-radius: 8px; border: 1px dashed var(--cbt-blue); }
        textarea.insight-box { width: 100%; height: 120px; border: 1px solid #ccc; border-radius: 4px; padding: 10px; font-family: monospace; font-size: 0.85rem; resize: vertical; margin-bottom: 10px;}

        .mobile-submit-btn { display: none !important; }
        .mobile-palette-toggle { display: none; }

        @media (max-width: 768px) {
            #home-screen { padding: 8px; }
            .home-card { padding: 15px; }
            .home-title { font-size: 1.5rem; }
            .logo-container { width: 55px; height: 55px; }
            
            .header { padding: 8px 12px; }
            .header-left { gap: 8px; }
            #cbt-title { display: none; } 
            
            .timer-module { width: 70px; }
            .timer-display { font-size: 1rem; }
            .pause-btn-fixed { width: 34px; height: 34px; margin-left: 2px;}

            .sync-container { flex-direction: column !important; align-items: stretch !important; gap: 10px; }
            .sync-container > div:last-child { width: 100%; justify-content: space-between; display: flex; gap: 10px; }
            .sync-container button { flex: 1; padding: 10px 4px; font-size: 0.85rem;}

            .mobile-submit-btn { display: block !important; padding: 4px 10px; font-size: 0.85rem; margin-left: 0; border-radius: 4px; }
            .desktop-submit-btn { display: none !important; }
            
            .top-action-bar { padding: 8px 10px; justify-content: space-between; gap: 5px; }
            .top-action-bar .btn { flex: 1; padding: 10px 4px; font-size: 0.85rem; text-align: center; margin: 0; border-radius: 4px;}
            
            .left-panel { border-right: none; padding-bottom: 160px; overflow-y: auto; height: 100%; }
            .q-body { padding: 15px; overflow-y: visible; }
            
            .right-panel { 
                position: fixed; bottom: 0; left: 0; width: 100%; height: auto; max-height: 60vh;
                background: white; transform: translateY(calc(100% - 40px)); 
                transition: transform 0.3s cubic-bezier(0.4, 0.0, 0.2, 1); 
                border-top: none; box-shadow: 0 -4px 15px rgba(0,0,0,0.15); 
                z-index: 1000; border-radius: 15px 15px 0 0; display: flex; flex-direction: column;
            }
            .right-panel.open { transform: translateY(0); }
            
            .mobile-palette-toggle { 
                display: flex; justify-content: center; align-items: center; 
                height: 40px; background: var(--cbt-blue); color: white; 
                font-weight: bold; cursor: pointer; border-radius: 15px 15px 0 0; flex-shrink: 0;
            }
            .palette-header { display: none; } 
            .palette-container-wrapper { flex: 1; overflow-y: auto; max-height: calc(60vh - 40px); }
            .palette-grid { grid-template-columns: repeat(auto-fit, minmax(35px, 1fr)); gap: 6px; padding: 10px;}
            .pal-btn { width: 35px; height: 35px; font-size: 0.85rem; }
            .option-row { flex-wrap: nowrap; }
            .radio-square { width: 40px; }
            .option-text { font-size: 1rem; padding: 10px; }
            .sub-card { flex-direction: column; text-align: center; }
            .sub-name { width: 100%; margin-bottom: 10px; border-bottom: 1px solid #eee; padding-bottom: 5px;}
        }

        .hide-for-review { display: none !important; }

        /* --- PHASE 1: PAUSE OVERLAY & DYNAMIC LEGEND BOXES --- */
        #pause-overlay {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(255, 255, 255, 0.85); backdrop-filter: blur(10px);
            display: none; flex-direction: column; align-items: center; justify-content: center;
            z-index: 10000;
        }
        .pause-card {
            background: white; padding: 40px; border-radius: 12px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.15); text-align: center;
            border-top: 5px solid var(--cbt-blue); width: 90%; max-width: 400px;
        }
        
        .palette-legend {
            display: grid; grid-template-columns: 1fr 1fr; gap: 12px;
            padding: 15px; background: #fdfdfd; border-bottom: 1px solid var(--border);
        }
        .legend-item { display: flex; align-items: center; gap: 8px; font-size: 0.8rem; font-weight: bold; color: #555; }
        .legend-stat-box { 
            width: 40px; height: 40px; border-radius: 6px; border: 1px solid var(--border); 
            display: flex; align-items: center; justify-content: center; 
            color: white; font-size: 0.95rem; font-weight: 900; flex-shrink: 0;
        }

        /* --- PHASE 2: FLOATING GEAR & TABBED SETTINGS MODAL --- */
        .floating-gear {
            position: fixed; bottom: 80px; right: 20px;
            width: 50px; height: 50px; background: var(--cbt-blue);
            color: white; border-radius: 50%; display: flex;
            align-items: center; justify-content: center; font-size: 1.5rem;
            cursor: pointer; box-shadow: 0 4px 15px rgba(0,0,0,0.2);
            z-index: 900; border: none; transition: 0.3s;
        }
        .floating-gear:hover { transform: rotate(45deg) scale(1.1); }
        
        #settings-overlay {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(0, 0, 0, 0.5); backdrop-filter: blur(5px);
            display: none; align-items: center; justify-content: center; z-index: 10001;
        }
        .settings-card {
            background: white; width: 95%; max-width: 500px; max-height: 90vh;
            border-radius: 12px; display: flex; flex-direction: column;
            box-shadow: 0 10px 30px rgba(0,0,0,0.2); overflow: hidden;
        }
        .settings-header {
            padding: 15px 20px; background: #fdfdfd; border-bottom: 1px solid var(--border);
            font-size: 1.2rem; font-weight: bold; color: var(--cbt-blue);
            display: flex; flex-direction: column; gap: 12px;
        }
        .master-tab-container {
            display: flex; justify-content: center; gap: 10px; background: #f0f0f0; padding: 4px; border-radius: 8px;
        }
        .master-tab {
            flex: 1; text-align: center; padding: 6px; border-radius: 6px; font-size: 0.9rem; font-weight: bold; cursor: pointer; color: #555; transition: 0.2s;
        }
        .master-tab.active { background: white; color: var(--cbt-blue); box-shadow: 0 2px 5px rgba(0,0,0,0.1); }
        
        .settings-body { padding: 20px; overflow-y: auto; flex: 1; }
        .settings-pane { display: none; }
        .settings-pane.active { display: block; }
        
        .settings-footer {
            padding: 15px 20px; background: #f9f9f9; border-top: 1px solid var(--border);
            display: flex; justify-content: flex-end; gap: 10px;
        }
        .settings-section { margin-bottom: 20px; border: 1px solid #eee; border-radius: 8px; padding: 15px; }
        .settings-section-title { font-weight: bold; font-size: 0.95rem; margin-bottom: 10px; display: flex; align-items: center; gap: 8px;}
        .settings-row { display: flex; justify-content: space-between; align-items: center; margin-bottom: 10px; font-size: 0.9rem;}
        
        /* The Pixel-Perfect Alignment Fix */
        .settings-input { width: 100%; padding: 5px; border: 1px solid var(--border); border-radius: 4px; text-align: center; font-weight: bold;}
        .aligned-input-grid { display: grid; grid-template-columns: 45px 25px 45px 20px; gap: 5px; align-items: center; text-align: left; }
    </style>
</head>
<body>

    <div id="pause-overlay">
        <div class="pause-card">
            <h2 style="margin-top:0; color:var(--text);">Test Paused ⏸️</h2>
