    <div id="cbt-screen" style="display: none; flex-direction: column; height: 100%;">
        <div class="header">
            <div class="header-left">
                <div class="home-icon" onclick="goHomeAlert()">🏠</div>
                <div style="font-size: 1.2rem; font-weight: bold; margin-left: 10px;" id="cbt-title">Exam Engine</div>
                <button id="mobile-submit-btn" class="btn btn-green mobile-submit-btn" onclick="submitExamManually()">Submit</button>
            </div>
            <div class="timer-container" id="header-timer-area">
                <div class="timer-module" id="sectional-timer-wrapper" style="display:none;">
                    <div class="timer-label">Section</div>
                    <div class="timer-display display-sec" id="sec-timer">15:00</div>
                </div>
                <div class="timer-module">
                    <div class="timer-label" id="global-timer-label">Total</div>
                    <div class="timer-display display-total" id="timer">00:00</div>
                </div>
                <button class="pause-btn-fixed" onclick="pauseTest()" title="Pause Test">⏸</button>
            </div>
        </div>

        <div class="main-content">
            <div class="left-panel">
                <div class="top-action-bar" id="action-bar-test">
                    <button class="btn btn-outline" onclick="loadPrevious()">Previous</button>
                    <button class="btn btn-blue" onclick="markForReview()">Mark for Review</button>
                    <button class="btn btn-blue" onclick="saveAndNext()">Save & Next</button>
                    <button class="btn btn-green desktop-submit-btn" onclick="submitExamManually()" id="btn-submit">Submit Test</button>
                </div>
                
                <div class="top-action-bar" id="action-bar-review" style="display: none; background: var(--review-bg);">
                    <button class="btn btn-outline" onclick="showDashboard()">← Back</button>
                    <button class="btn" style="background:#24292e; color: white;" onclick="editJsonOnGithub()">✏️ Edit JSON</button>
                    <button class="btn btn-outline" onclick="loadPrevious()">Previous</button>
                    <button class="btn btn-blue" onclick="loadNext()">Next →</button>
                </div>

                <div class="filter-bar" id="review-filter-bar" style="display: none; padding: 10px 20px; background: #fff; border-bottom: 1px solid var(--border); overflow-x: auto; gap: 10px; align-items: center; flex-shrink: 0;">
                    <select id="review-subj-filter" class="filter-chip" onchange="updateReviewTopicDropdown(); applyReviewFilters()" style="width:auto; margin:0; padding:4px 10px;">
                        <option value="all">All Subjects</option>
                    </select>
                    <select id="review-topic-filter" class="filter-chip" onchange="applyReviewFilters()" style="width:auto; margin:0; padding:4px 10px;">
                        <option value="all">All Topics</option>
                    </select>
                    <button class="filter-chip" id="rev-filt-correct" onclick="toggleReviewStatusFilter('correct')">✅ Correct</button>
                    <button class="filter-chip" id="rev-filt-wrong" onclick="toggleReviewStatusFilter('wrong')">❌ Wrong</button>
                    <button class="filter-chip" id="rev-filt-skipped" onclick="toggleReviewStatusFilter('skipped')">⏭️ Skipped</button>
                    <button class="filter-chip" id="rev-filt-sluggish" onclick="toggleReviewSort('sluggish')">⏱️ Sluggish</button>
                </div>

                <div class="q-header">
                    <div style="display: flex; align-items: center;">
                        <div>Question No. <span id="q-num-display">1</span></div>
                        <div id="q-status-badge"></div>
                    </div>
                    
                    <div id="lang-toggle-container">
                        <select id="lang-select" onchange="toggleLanguage()" style="padding: 2px 4px; border: 1px solid var(--border); border-radius: 4px; font-size: 0.85rem; outline: none; cursor: pointer; background: #fff; font-weight: bold; color: var(--text); margin: 0; width: max-content;">
                            <option value="hi">H</option>
                            <option value="en">E</option>
                        </select>
                    </div>
                </div>
                
                <div class="q-body">
                    <div id="q-text" style="font-weight: bold; margin-bottom: 20px;">Loading...</div>
