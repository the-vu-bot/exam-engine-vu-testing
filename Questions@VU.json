                    <div class="stat-box"><div>Net Score</div><div class="stat-value" id="dash-score" style="color:var(--cbt-blue);">0</div></div>
                    <div class="stat-box"><div>Correct</div><div class="stat-value" id="dash-correct" style="color:var(--cbt-green);">0</div></div>
                    <div class="stat-box"><div>Wrong</div><div class="stat-value" id="dash-wrong" style="color:var(--cbt-red);">0</div></div>
                    <div class="stat-box"><div>Accuracy</div><div class="stat-value" id="dash-acc">0%</div></div>
                    <div class="stat-box"><div>Attempted</div><div class="stat-value" id="dash-att">0</div></div>
                    <div class="stat-box"><div>Total Time</div><div class="stat-value" id="dash-time">0s</div></div>
                </div>
                
                <div class="subject-analysis" id="detailed-stats-area"></div>

                <div class="insights-area">
                    <div style="font-weight:bold; margin-bottom:10px; color:var(--cbt-blue);">Copy Record for Document</div>
                    <textarea class="insight-box" id="insight-text" readonly></textarea>
                    <button class="btn btn-outline" onclick="copyInsights(this)">📋 Copy to Clipboard</button>
