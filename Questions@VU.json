            <button class="btn btn-blue" style="width:100%; font-size:1.1rem; padding: 12px;" onclick="resumeTest()">Resume Test</button>
        </div>
    </div>

    <button class="floating-gear" onclick="openSettings()" title="Engine Settings">⚙️</button>

    <div id="settings-overlay">
        <div class="settings-card">
            <div class="settings-header">
                <div style="display: flex; justify-content: space-between; align-items: center; width: 100%;">
                    Engine Settings <span style="cursor:pointer; color:#888;" onclick="closeSettings()">✖</span>
                </div>
                <div class="master-tab-container">
                    <div id="tab-tests" class="master-tab active" onclick="switchSettingsTab('tests')">📝 Tests</div>
                    <div id="tab-calc" class="master-tab" onclick="switchSettingsTab('calc')">🧮 Calc</div>
                </div>
            </div>
            
            <div class="settings-body">
                <div id="pane-tests" class="settings-pane active">
                    <div class="settings-section">
                        <div class="settings-section-title" style="color: var(--cbt-purple);">🎯 Active Subjects Filter (Global)</div>
                        <div class="subject-toggle-container" id="modal-subject-toggles"></div>
                    </div>

                    <div class="settings-section">
                        <div class="settings-section-title" style="color: #d9a05b;">⚡ Sprint Configuration</div>
                        <div class="settings-row" style="background:#fcfcfc; padding:8px 12px; border-radius:6px; border:1px solid #eee;">
                            <div style="flex:1;"><strong style="color:#333;">Sprint Limits</strong><div style="font-size:0.75rem; color:#888;">Mins & Qs per sprint.</div></div>
                            <div class="aligned-input-grid">
                                <input type="number" id="set-sprint-time" class="settings-input" value="15">
                                <span style="font-size:0.8rem; color:#888;">Min</span>
                                <input type="number" id="set-sprint-qs" class="settings-input" value="25">
                                <span style="font-size:0.8rem; color:#888;">Qs</span>
                            </div>
                        </div>
                    </div>

                    <div class="settings-section">
                        <div class="settings-section-title" style="color: #d9534f;">🏆 Full Mock Configuration</div>
                        <div class="settings-row" style="background:#fcfcfc; padding:8px 12px; border-radius:6px; border:1px solid #eee;">
                            <div style="flex:1;"><strong style="color:#333;">Global Mock Limits</strong><div style="font-size:0.75rem; color:#888;">Total Stopwatch & Qs.</div></div>
                            <div class="aligned-input-grid">
                                <input type="number" id="set-mock-global-time" class="settings-input" value="60" oninput="syncFromGlobal()">
                                <span style="font-size:0.8rem; color:#888;">Min</span>
                                <input type="number" id="set-mock-global-qs" class="settings-input" value="100" oninput="syncFromGlobal()">
                                <span style="font-size:0.8rem; color:#888;">Qs</span>
                            </div>
                        </div>
                        
                        <div style="margin-top:15px;">
                            <strong style="color:#333; font-size:0.9rem;">Sectional Distribution</strong>
                            <div style="display:flex; margin-top:8px; border-radius:6px; overflow:hidden; border: 1px solid var(--border);">
                                <div id="btn-auto-split" style="flex:1; text-align:center; padding:8px; font-size:0.85rem; font-weight:bold; cursor:pointer; background:var(--cbt-blue); color:white;" onclick="setSplitMode('auto')">Auto-Split Time</div>
                                <div id="btn-custom-split" style="flex:1; text-align:center; padding:8px; font-size:0.85rem; font-weight:bold; cursor:pointer; background:#eee; color:#555;" onclick="setSplitMode('custom')">Custom Split Time</div>
                            </div>
                            <div id="sectional-distribution-container" style="margin-top: 10px; display:flex; flex-direction:column; gap:5px;"></div>
