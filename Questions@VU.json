                    <span id="palette-toggle-text">▲ Show Question Palette</span>
                </div>
                <div class="palette-header" id="palette-title">▶ Question Palette</div>
                
                <div class="palette-legend" id="legend-test-mode">
                    <div class="legend-item"><div class="legend-stat-box status-answered" id="count-answered">0</div> Answered</div>
                    <div class="legend-item"><div class="legend-stat-box status-not-answered" id="count-not-answered">0</div> Unattempted</div>
                    <div class="legend-item"><div class="legend-stat-box status-review" id="count-review">0</div> Review</div>
                    <div class="legend-item"><div class="legend-stat-box" style="background: white; color: #333;" id="count-unvisited">0</div> Not Visited</div>
                </div>
                
                <div class="palette-legend" id="legend-review-mode" style="display: none;">
                    <div class="legend-item"><div class="legend-stat-box rev-correct" id="count-correct">0</div> Correct</div>
                    <div class="legend-item"><div class="legend-stat-box rev-incorrect" id="count-wrong">0</div> Wrong</div>
                    <div class="legend-item"><div class="legend-stat-box rev-skipped" id="count-skipped">0</div> Skipped</div>
                    <div class="legend-item"><div class="legend-stat-box" style="background: white; color: #333;" id="count-rev-unvisited">0</div> Not Visited</div>
                </div>

                <div class="palette-container-wrapper" id="palette-wrapper"></div>
            </div>
